{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-10-17/server.schema.json",
  "name": "io.github.cola-sk/figma-mcp",
  "description": "MCP server that converts Figma designs to production-ready HTML + Tailwind CSS code",
  "websiteUrl": "https://github.com/cola-sk/figma-mcp",
  "repository": {
    "url": "https://github.com/cola-sk/figma-mcp",
    "source": "github"
  },
  "version": "1.0.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "figma-context-mcp",
      "version": "1.0.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Your personal access token for the Figma API",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "FIGMA_ACCESS_TOKEN"
        }
      ]
    }
  ]
}